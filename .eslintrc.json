{
  "extends": ["next/core-web-vitals", "prettier"],

  "plugins": ["unicorn"],

  "rules": {
    "unicorn/no-empty-file": "error",
    "eslint lines-between-class-members": ["error", "never"],
    "no-multiple-empty-lines": [
      "error",
      {
        "max": 1,
        "maxEOF": 0,
        "maxBOF": 0
      }
    ]
  }
}
